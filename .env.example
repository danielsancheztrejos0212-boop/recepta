# ─────────────────────────────────────────────────────────────────────────────
# Recepta — variables de entorno
#
# Copia este archivo a ".env" y llena cada valor.
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# El archivo .env NUNCA se sube a git (ya está en .gitignore): tiene secretos.
# Si falta alguna variable obligatoria, la app no arranca y te dice cuál es.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (Neon, plan free) ──────────────────────────────────────────
# Créala en https://neon.tech → New Project → copia la "Connection string".
# Debe empezar por postgresql:// y terminar en ?sslmode=require
DATABASE_URL="postgresql://usuario:clave@ep-algo-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── IA (Groq, plan free) ─────────────────────────────────────────────────────
# Sácala en https://console.groq.com/keys → Create API Key. Empieza por "gsk_".
GROQ_API_KEY="gsk_pega_aqui_tu_api_key_de_groq"

# Modelo de IA. El default es el único que necesitas; cámbialo solo si Groq lo retira.
GROQ_MODEL="llama-3.3-70b-versatile"

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Este token te lo INVENTAS tú. Solo tiene que ser el mismo aquí y en la casilla
# "Token de verificación" cuando das de alta el webhook en Meta.
WHATSAPP_VERIFY_TOKEN="inventate-una-frase-larga-aqui-123"

# App Secret de tu app de Meta: developers.facebook.com → tu app →
# Configuración → Básica → "Clave secreta de la aplicación" → Mostrar.
# Con esto se verifica que los webhooks vienen de verdad de Meta.
WHATSAPP_APP_SECRET="pega_aqui_el_app_secret_de_meta"

# Versión de la Graph API. Cámbiala solo cuando Meta jubile la actual.
GRAPH_API_VERSION="v23.0"

# ── Panel de administración ──────────────────────────────────────────────────
# La clave con la que entras a /admin/. Mínimo 12 caracteres.
# Genera una segura:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN="cambia-esto-por-una-clave-larga-y-secreta"

# ── Ajustes del servidor ─────────────────────────────────────────────────────
# Puerto local. En Render lo asigna la plataforma automáticamente: no lo toques allá.
PORT=3000

# Cuánto espera el agente antes de responder, en milisegundos.
# Este es el "efecto humano": 10000 = 10 segundos. Si el paciente manda varios
# mensajes seguidos, el contador se reinicia y contesta UNA sola vez al final.
RESPONSE_DELAY_MS=10000

# Nivel de log: debug | info | warn | error. Deja "info" salvo que estés depurando.
LOG_LEVEL="info"
